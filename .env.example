# Copy this file to .env.local and fill in your values

# MongoDB - Get from MongoDB Atlas (mongodb.com)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/estateos?retryWrites=true&w=majority

# App
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
